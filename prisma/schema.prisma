generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String   @unique
  phone     String?
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  address   String?
  orders    Order[]
}

model Order {
  id                   Int             @id @default(autoincrement())
  userId               Int
  status               OrderStatus     @default(PENDING)
  totalAmount          Float
  requiresNotarization Boolean         @default(false)
  requiresHardCopy     Boolean         @default(false)
  urgency              String          @default("normal")
  uspsTracking         String?
  createdAt            DateTime        @default(now())
  paymentProvider      PaymentProvider @default(STRIPE)
  deliveryUrl          String?
  metadata             String?
  paymentMethod        String?
  hasTranslation       Boolean         @default(true)
  hasNotary            Boolean         @default(false)
  sentAt               DateTime?
  discountAmount       Float?          @default(0)
  discountPercentage   Float?          @default(0)
  extraDiscount        Float?          @default(0)
  finalPaidAmount      Float?
  sourceLanguage       SourceLanguage  @default(PT_BR)
  cancellation_reason  String?
  documents            Document[]
  user                 User            @relation(fields: [userId], references: [id])
}

model Document {
  id                     Int             @id @default(autoincrement())
  orderId                Int
  docType                String
  originalFileUrl        String
  translatedFileUrl      String?
  translatedText         String?
  exactNameOnDoc         String?
  createdAt              DateTime        @default(now())
  translation_status     String          @default("pending")
  delivery_pdf_url       String?
  isReviewed             Boolean         @default(false)
  externalTranslationUrl String?
  pageRotations          Json?
  sourceLanguage         SourceLanguage?
  // ── Scope fields (cotejo financeiro) ──────────────────────────────────────
  billablePages          Int?            // Pages included in the quote (client pays for these)
  totalPages             Int?            // Total pages in the original uploaded document
  excludedFromScope      Boolean         @default(false) // Present for transparency, NOT to be translated
  approvedKitUrl         String?         // Frozen preview kit URL (approved by translator)
  // ──────────────────────────────────────────────────────────────────────────
  order                  Order           @relation(fields: [orderId], references: [id])
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

enum SourceLanguage {
  PT_BR
  ES
}

enum PaymentProvider {
  STRIPE
  PARCELADO_USA
}

enum Role {
  CLIENT
  OPERATIONS
  FINANCIAL
  TECHNICAL
  PARTNER
}

enum OrderStatus {
  PENDING
  TRANSLATING
  NOTARIZING
  COMPLETED
  PAID
  READY_FOR_REVIEW
  MANUAL_TRANSLATION_NEEDED
  CANCELLED
  PENDING_PAYMENT
  AWAITING_VERIFICATION
}
