# -----------------------------------------------------------------------------
# Franklin - local environment
# Copy to .env and fill with real values.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Required to boot the app
# PostgreSQL is mandatory. There is no supported SQLite fallback today.
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=10"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# -----------------------------------------------------------------------------
# Required for the critical flow today
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# Strongly recommended for local links, callbacks and internal server calls
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
INTERNAL_APP_URL="http://127.0.0.1:3000"

# -----------------------------------------------------------------------------
# Required if you want auto-translation
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-..."

# -----------------------------------------------------------------------------
# Required if you want email sending
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_..."
ADMIN_EMAIL="ops@example.com"
EMAIL_FROM="Promobi <desk@example.com>"
TEAM_EMAIL="ops@example.com"
RESEND_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# Required if you want structured preview / PDF kit generation
# If omitted, the app will try local fallbacks such as http://127.0.0.1:3001.
# -----------------------------------------------------------------------------
GOTENBERG_URL="http://127.0.0.1:3001/forms/chromium/convert/html"
GOTENBERG_TIMEOUT_MS="45000"

# -----------------------------------------------------------------------------
# Optional payment / notification integrations
# -----------------------------------------------------------------------------
PARCELADO_MERCHANT_CODE=""
PARCELADO_API_KEY=""
PARCELADO_API_URL="https://api.parceladousa.com/v1"
WHATSAPP_API_KEY=""

# -----------------------------------------------------------------------------
# Optional feature flags
# Defaults are false when omitted.
# -----------------------------------------------------------------------------
USE_STRUCTURED_TRANSLATION="true"
ENABLE_STRUCTURED_PREVIEW="true"
ENABLE_STRUCTURED_PREVIEW_KIT="true"
USE_TRANSLATION_V2="false"

# -----------------------------------------------------------------------------
# Optional operational policy
# -----------------------------------------------------------------------------
PROMOBI_MANUAL_PAYMENT_RELEASE_POLICY=""
